# XANENE OPS - Environment Configuration
# Copy this file to .env and update the values

# Application
APP_NAME=XANENE OPS
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://xanene:YOUR_SECURE_PASSWORD@localhost:5432/xanene_ops

# JWT Authentication
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-characters

# Token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Origins (comma-separated list)
CORS_ORIGINS=["http://localhost:8000","https://your-domain.com"]

# PostgreSQL (for Docker)
DB_PASSWORD=xanene_secure_pass_2024
POSTGRES_DB=xanene_ops
POSTGRES_USER=xanene
